{{ form_start(form, {attr: {novalidate: 'novalidate', enctype: 'multipart/form-data'}}) }}
{{ form_errors(form) }}

<div class="row g-3">
    <div class="col-md-6">{{ form_row(form.nom) }}</div>
    <div class="col-md-6">{{ form_row(form.prenom) }}</div>
    <div class="col-md-6">{{ form_row(form.email) }}</div>
    <div class="col-md-6">{{ form_row(form.telephone) }}</div>
    <div class="col-md-6">{{ form_row(form.dateNaissance) }}</div>
    <div class="col-md-6">{{ form_row(form.filiere) }}</div>
    <div class="col-md-6">{{ form_row(form.niveau) }}</div>
    <div class="col-md-6">{{ form_row(form.moyenneGenerale) }}</div>
    <div class="col-md-6">{{ form_row(form.actif) }}</div>
    <div class="col-md-6">{{ form_row(form.photoFile) }}</div>
    <div class="col-12">{{ form_row(form.adresse) }}</div>
</div>

<div class="mt-4 d-flex gap-2">
    <button class="btn btn-primary"><i class="bi bi-check-circle"></i> Enregistrer</button>
    <a href="{{ path('etudiant_index') }}" class="btn btn-light">Annuler</a>
</div>
{{ form_end(form) }}