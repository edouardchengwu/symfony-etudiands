{% extends 'base.html.twig' %}
{% block title %}Tableau de bord{% endblock %}
{% block body %}

{% set joursFR = ['Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi','Dimanche'] %}
{% set moisFR = ['','Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'] %}
{% set jourIndex = ("now"|date('N'))|number_format %}
{% set moisIndex = ("now"|date('n'))|number_format %}

<div class="d-flex flex-wrap justify-content-between align-items-end mb-4 fade-in-up">
    <div>
        <h3 class="fw-bold mb-1"><i class="bi bi-speedometer2"></i> Tableau de bord</h3>
        <p class="text-muted mb-0">
            Bonjour {{ app.user.nomComplet ?? app.user.userIdentifier }} 👋 — {{ joursFR[jourIndex-1] }} {{ "now"|date('j') }} {{ moisFR[moisIndex] }} {{ "now"|date('Y') }}
        </p>
    </div>
    <div class="text-muted small" id="liveClock"></div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3 fade-in-up delay-1">
        <div class="card stat-card p-3" style="background: linear-gradient(135deg,#2563eb,#1e3a8a);">
            <i class="bi bi-people-fill stat-icon"></i>
            <div class="small opacity-75">Total étudiants</div>
            <div class="display-6 fw-bold"><span class="counter" data-target="{{ total }}">0</span></div>
        </div>
    </div>
    <div class="col-md-3 fade-in-up delay-2">
        <div class="card stat-card p-3" style="background: linear-gradient(135deg,#16a34a,#065f46);">
            <i class="bi bi-person-check-fill stat-icon"></i>
            <div class="small opacity-75">Actifs</div>
            <div class="display-6 fw-bold"><span class="counter" data-target="{{ actifs }}">0</span></div>
        </div>
    </div>
    <div class="col-md-3 fade-in-up delay-3">
        <div class="card stat-card p-3" style="background: linear-gradient(135deg,#dc2626,#7f1d1d);">
            <i class="bi bi-person-x-fill stat-icon"></i>
            <div class="small opacity-75">Inactifs</div>
            <div class="display-6 fw-bold"><span class="counter" data-target="{{ inactifs }}">0</span></div>
        </div>
    </div>
    <div class="col-md-3 fade-in-up delay-4">
        <div class="card stat-card p-3" style="background: linear-gradient(135deg,#d97706,#78350f);">
            <i class="bi bi-graph-up-arrow stat-icon"></i>
            <div class="small opacity-75">Moyenne générale</div>
            <div class="display-6 fw-bold">
                {% if moyenneGlobale is not null %}
                    <span class="counter" data-target="{{ moyenneGlobale }}" data-decimals="2">0</span>
                {% else %}
                    —
                {% endif %}
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6 fade-in-up delay-5">
        <div class="card p-3">
            <h6 class="fw-bold mb-3"><i class="bi bi-pie-chart-fill text-primary"></i> Répartition par filière</h6>
            <canvas id="chartFiliere" height="200"></canvas>
        </div>
    </div>
    <div class="col-md-6 fade-in-up delay-5">
        <div class="card p-3">
            <h6 class="fw-bold mb-3"><i class="bi bi-bar-chart-fill text-primary"></i> Répartition par niveau</h6>
            <canvas id="chartNiveau" height="200"></canvas>
        </div>
    </div>
</div>

<div class="card p-3 fade-in-up delay-6">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-bold mb-0"><i class="bi bi-clock-history text-primary"></i> Derniers étudiants inscrits</h6>
        <a href="{{ path('etudiant_index') }}" class="btn btn-sm btn-outline-primary">Voir tout <i class="bi bi-arrow-right"></i></a>
    </div>
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead><tr><th>Étudiant</th><th>Matricule</th><th>Filière</th><th>Niveau</th><th></th></tr></thead>
            <tbody>
            {% for e in derniersInscrits %}
                <tr>
                    <td>{{ e.nomComplet }}</td>
                    <td><code>{{ e.matricule }}</code></td>
                    <td>{{ e.filiere }}</td>
                    <td><span class="badge bg-primary-subtle text-primary badge-niveau">{{ e.niveau }}</span></td>
                    <td class="text-end"><a href="{{ path('etudiant_show', {id: e.id}) }}" class="btn btn-sm btn-light"><i class="bi bi-eye"></i></a></td>
                </tr>
            {% else %}
                <tr><td colspan="5" class="text-center text-muted py-3">Aucun étudiant enregistré pour le moment.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script>
// Horloge en direct
function updateClock() {
    const el = document.getElementById('liveClock');
    if (!el) return;
    const now = new Date();
    el.textContent = now.toLocaleTimeString('fr-FR');
}
updateClock();
setInterval(updateClock, 1000);

// Compteurs animés (effet rebond)
function easeOutBack(t) {
    const c1 = 1.70158;
    const c3 = c1 + 1;
    return 1 + c3 * Math.pow(t - 1, 3) + c1 * Math.pow(t - 1, 2);
}

document.querySelectorAll('.counter').forEach(el => {
    const target = parseFloat(el.dataset.target);
    const decimals = parseInt(el.dataset.decimals || '0', 10);
    const duration = 1600;
    const start = performance.now();

    function tick(now) {
        const progress = Math.min((now - start) / duration, 1);
        const eased = easeOutBack(progress);
        const value = Math.max(target * eased, 0);
        el.textContent = decimals ? value.toFixed(decimals) : Math.round(value);
        if (progress < 1) requestAnimationFrame(tick);
        else el.textContent = decimals ? target.toFixed(decimals) : target;
    }
    requestAnimationFrame(tick);
});

new Chart(document.getElementById('chartFiliere'), {
    type: 'doughnut',
    data: {
        labels: {{ parFiliereLabels|json_encode|raw }},
        datasets: [{ data: {{ parFiliereData|json_encode|raw }}, backgroundColor: ['#2563eb','#16a34a','#d97706','#dc2626','#7c3aed','#0891b2','#db2777'] }]
    },
    options: {
        animation: { duration: 1400, easing: 'easeOutElastic', animateRotate: true, animateScale: true },
        plugins: { legend: { position: 'bottom' } }
    }
});
new Chart(document.getElementById('chartNiveau'), {
    type: 'bar',
    data: {
        labels: {{ parNiveauLabels|json_encode|raw }},
        datasets: [{ label: 'Étudiants', data: {{ parNiveauData|json_encode|raw }}, backgroundColor: '#2563eb' }]
    },
    options: {
        animation: { duration: 1300, easing: 'easeOutBounce' },
        plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
    }
});
</script>
{% endblock %}